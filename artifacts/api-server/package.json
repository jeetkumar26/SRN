    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "nodemailer": "^6.9.16",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express-rate-limit": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
