{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env ./build.mjs && node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
