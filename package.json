    "@tanstack/react-query": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-native-vector-icons": "^6.4.18",
    "@ungap/structured-clone": "^1.3.0",
    "@workspace/api-client-react": "workspace:*",
    "babel-plugin-module-resolver": "^5.0.2",
