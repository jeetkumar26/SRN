# ============================================================
# SRN Environment Configuration — EXAMPLE FILE
# Copy to .env and fill in real values.
# NEVER commit .env to git — only commit this .env.example.
# ============================================================

NODE_ENV=development
PORT=3000

# ── Firebase Admin SDK ───────────────────────────────────────
#
# LOCAL DEV — point to service account JSON file on disk.
# The file firebase-service-account.json is at the project root.
# Path is relative to artifacts/api-server/ (where the server runs).
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=../../firebase-service-account.json

# CLOUD / RAILWAY — paste the entire JSON as a single minified line.
# Run: cat firebase-service-account.json | tr -d '\n'  to minify.
# This takes priority over FIREBASE_SERVICE_ACCOUNT_KEY_PATH.
# FIREBASE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"skill-requirement-network",...}

# ── Razorpay Payments ────────────────────────────────────────
#
# STEP 1: Create account at https://razorpay.com (free, 5 minutes)
# STEP 2: Complete KYC (PAN / GST required for live keys)
# STEP 3: Dashboard → Settings → API Keys → Generate Key
#
# Test keys (rzp_test_...) for development — no real money moves.
# Live keys (rzp_live_...) for production — requires KYC approval.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# STEP 4: Dashboard → Settings → Webhooks → Add New Webhook
#   Webhook URL (local): use ngrok → https://XXXX.ngrok.io/api/subscriptions/webhook
#   Webhook URL (prod):  https://your-railway-domain.railway.app/api/subscriptions/webhook
#   Events to select: payment.captured, subscription.activated, subscription.cancelled
#   Set a strong random secret string and paste it below.
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SMTP Email ───────────────────────────────────────────────
#
# OPTION A — Gmail App Password (free, easy):
#   1. Google Account → Security → enable 2-Step Verification
#   2. Google Account → search "App Passwords"
#   3. Generate for app: Mail, device: Other (name it "SRN")
#   4. Copy the 16-character password (shown only once)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# OPTION B — Brevo (300 free emails/day):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your@email.com
#   SMTP_PASS=your_brevo_smtp_key

# OPTION C — Resend (3,000 free emails/month):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx

# Sender name + email shown in email "From" field
SMTP_FROM=SRN Platform <noreply@srn.digitalnextworld.com>

# ── App Configuration ────────────────────────────────────────
# Public URL of the backend — used in email unsubscribe links.
# Local: http://localhost:3000
# Production: https://your-railway-domain.railway.app
APP_URL=http://localhost:3000

# CORS allowed origin. Use * for development.
# In production, set to your frontend domain, e.g.:
# CORS_ORIGIN=https://srn.digitalnextworld.com
CORS_ORIGIN=*

# Log level: trace | debug | info | warn | error
# Use debug for development, info for production.
LOG_LEVEL=debug

# ── Railway Deployment Checklist ─────────────────────────────
# In Railway dashboard → Variables, set:
#
#   NODE_ENV                        = production
#   PORT                            = (Railway sets this automatically — do NOT override)
#   FIREBASE_SERVICE_ACCOUNT_KEY_JSON = <minified JSON from firebase-service-account.json>
#   RAZORPAY_KEY_ID                 = rzp_live_XXXXXXXXXXXXXXXX
#   RAZORPAY_KEY_SECRET             = XXXXXXXXXXXXXXXXXXXXXXXX
#   RAZORPAY_WEBHOOK_SECRET         = XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#   SMTP_HOST                       = smtp.gmail.com
#   SMTP_PORT                       = 587
#   SMTP_USER                       = your@gmail.com
#   SMTP_PASS                       = xxxx xxxx xxxx xxxx
#   SMTP_FROM                       = SRN Platform <noreply@srn.digitalnextworld.com>
#   APP_URL                         = https://your-railway-domain.railway.app
#   CORS_ORIGIN                     = *
#   LOG_LEVEL                       = info